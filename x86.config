# Target System
config_target_x86=y
config_target_x86_generic=y
config_target_x86_generic_generic=y

# Kernel Options
config_kernel_kmod-usb-core=y
config_kernel_kmod-usb-ohci=y
config_kernel_kmod-usb-ehci=y
config_kernel_kmod-usb2=y
config_kernel_kmod-usb-storage=y
config_kernel_kmod-usb-storage-uas=y
config_kernel_kmod-sdhci=y
config_kernel_kmod-sdhci-pci=y
config_kernel_kmod-r8169=y
config_kernel_kmod-usb-uhci=y
config_kernel_kmod-kvm-intel=y
config_kernel_kmod-kvm-x86=y

# Filesystem
config_target_images_gzip=y
config_target_rootfs_partsize=300
config_target_kernel_partsize=16

# LuCI Web Interface
config_package_luci=y
config_package_luci-app-firewall=y
config_package_luci-app-statistics=y
config_package_luci-app-ntpc=y
config_package_luci-app-sqm=y
config_package_luci-app-ddns=y
config_package_luci-i18n-base-zh-cn=y
config_package_luci-i18n-firewall-zh-cn=y
config_package_luci-i18n-sqm-zh-cn=y
config_package_luci-i18n-ddns-zh-cn=y

# Network & Security
config_package_dnsmasq_full=y
config_package_dnsmasq_full_dnssec=y
config_package_dnsmasq_full_conntrack=y
config_package_kmod-tun=y
config_package_openvpn-openssl=y
config_package_openvpn-easy-rsa=y
config_package_wireguard-tools=y
config_package_wireguard=y
config_package_kmod-wireguard=y

# Proxy & Ad Blocking
config_package_luci-app-passwall=y
config_package_luci-app-passwall_include_shadowsocks=y
config_package_luci-app-passwall_include_v2ray=y
config_package_luci-app-passwall_include_trojan=y
config_package_luci-app-passwall_include_simple_obfs=y
config_package_luci-app-passwall_include_v2ray_plugin=y
config_package_luci-app-adguardhome=y
config_package_adguardhome=y
config_package_smartdns=y

# Utilities
config_package_htop=y
config_package_nano=y
config_package_curl=y
config_package_wget=y
config_package_iperf3=y
config_package_zram=y
config_package_kmod-zram=y

# System
config_package_kmod-usb-serial=y
config_package_kmod-usb-serial-ftdi=y
config_package_kmod-usb-serial-pl2303=y
config_package_kmod-usb-serial-wwan=y
config_package_kmod-usb-net=y
config_package_kmod-usb-net-cdc-ether=y
config_package_kmod-usb-net-rndis=y
config_package_kmod-usb-net-asix=y
config_package_kmod-usb-net-asix-ax88179=y

# Optional: Enable SSH password login (for initial setup)
config_package_dropbear=y
config_package_dropbear_server=y
config_dropbear_password=y

# Build Options
config_build_user="SV3-26026 Custom Build"
config_grub_title="OpenWrt Lean's Build for SV3-26026"
config_openwrt_version="24.10"
